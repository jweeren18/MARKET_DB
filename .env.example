# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/market_intelligence
TIMESCALEDB_ENABLED=true

# Schwab API
SCHWAB_API_KEY=your_api_key_here
SCHWAB_API_SECRET=your_api_secret_here
SCHWAB_CALLBACK_URL=http://localhost:8000/auth/callback

# Application
BACKEND_PORT=8000
FRONTEND_PORT=3000
ENV=development
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-this-in-production

# Batch Jobs
DATA_INGESTION_SCHEDULE=0 16 * * *
SCORING_SCHEDULE=0 17 * * *

# Feature Flags
ENABLE_SENTIMENT=false
