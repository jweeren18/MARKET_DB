# Database
# NOTE: If you have PostgreSQL installed locally, it may conflict with Docker on port 5432
# In that case, use port 5433: postgresql://postgres:password@127.0.0.1:5433/market_intelligence
DATABASE_URL=postgresql://postgres:password@127.0.0.1:5432/market_intelligence
TIMESCALEDB_ENABLED=true

# Schwab API
# IMPORTANT: Callback URL must use HTTPS (see SCHWAB_API_SETUP.md for SSL certificate setup)
SCHWAB_API_KEY=your_api_key_here
SCHWAB_API_SECRET=your_api_secret_here
SCHWAB_CALLBACK_URL=https://127.0.0.1:8000/auth/callback

# Application
BACKEND_PORT=8000
FRONTEND_PORT=3000
ENV=development
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-change-this-in-production

# Batch Jobs
DATA_INGESTION_SCHEDULE=0 16 * * *
SCORING_SCHEDULE=0 17 * * *

# Feature Flags
ENABLE_SENTIMENT=false
